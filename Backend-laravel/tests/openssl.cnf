# Configuración mínima de OpenSSL para tests locales.
# Este archivo permite que openssl_pkey_new() funcione en entornos Windows
# donde no hay openssl.cnf instalado globalmente.

[req]
default_bits       = 2048
default_md         = sha256
distinguished_name = req_distinguished_name
x509_extensions    = v3_req
prompt             = no

[req_distinguished_name]
C  = CL
ST = RM
O  = Tenri ERP Tests
CN = localhost

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = localhost
