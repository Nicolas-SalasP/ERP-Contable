# Archivo de ejemplo para pruebas E2E locales.
# Copiar como Frontend/.env.e2e en entorno localhost/probatorio.
# No usar credenciales productivas, certificados reales, CAF reales ni tokens SII.

E2E_BASE_URL=http://localhost:3000
E2E_USER_EMAIL=superadmin@example.test
E2E_USER_PASSWORD=change-me-local-only
