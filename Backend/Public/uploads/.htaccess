# 1. Prevenir la lectura del directorio (Evita que vean qué archivos existen)
Options -Indexes

# 2. Impedir forzosamente la ejecución de CGI
Options -ExecCGI

# 3. Desactivar el motor de PHP de forma segura (Cubre múltiples versiones)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 4. Remover handlers de ejecución por si Apache intenta forzarlos
RemoveHandler .cgi .php .php3 .php4 .php5 .php7 .php8 .phtml .pl .py .jsp .asp .htm .shtml .sh

# 5. BLOQUEO TOTAL: Denegar acceso a todo script o ejecutable malicioso 
# El (?i) lo hace insensible a mayúsculas (bloquea .PHP, .PhP, .php, etc.)
<FilesMatch "(?i)\.(php|php[0-9]|phtml|inc|pl|py|jsp|asp|htm|html|shtml|sh|cgi|exe|bat|cmd|js|vbs|jar)$">
    Require all denied
</FilesMatch>

# 6. Anti MIME-Sniffing (Previene que un .pdf falso se ejecute como script)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>