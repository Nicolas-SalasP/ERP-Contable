# 1. Desactivar el motor de PHP por completo en esta carpeta
php_flag engine off

# 2. Impedir forzosamente la ejecución de cualquier script
Options -ExecCGI
RemoveHandler .cgi .php .php3 .php4 .php5 .php7 .php8 .phtml .pl .py .jsp .asp .htm .shtml .sh

# 3. Bloquear el acceso a cualquier archivo que no sea imagen/documento permitido
<FilesMatch "\.(php|php[0-9]|phtml|pl|py|jsp|asp|htm|shtml|sh|cgi|exe|bat|cmd)$">
    Require all denied
</FilesMatch>

# 4. Prevenir la lectura del directorio si no hay archivo index
Options -Indexes